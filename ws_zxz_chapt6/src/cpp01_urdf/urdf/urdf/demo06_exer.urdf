<!-- Four-wheeled robot model -->
<robot name="robot_model">

  <!-- set color -->
  <material name="yellow">
    <color rgba="0.9 0.6 0.0 0.5"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 0.5"/>
  </material>

  <!-- set base_footprint -->
  <link name="base_footprint">
    <visual>
      <geometry>
        <sphere radius="0.001"/>
      </geometry>
    </visual>
  </link>

  <!-- set base_link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.2 0.12 0.07"/>
      </geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <!-- set joint base_link - base_footprint -->
  <joint name="base_link2base_footprint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- 0.025+0.035 -->
    <origin xyz="0.0 0.0 0.06"/>
  </joint>

<!-- ******************************* 1 ******************************** -->
  <!-- set front_left_wheel  -->
  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="black"/>
      <origin rpy="1.57 0.0 0.0"/>
      <!-- <axis xyz="0 1 0"/> -->
    </visual>
  </link>

  <!-- set joint front_left_wheel to base_link  -->
  <joint name="front_left_wheel_to_base_link" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <!-- <origin rpy="1.57 0.0 0.0"/> -->
    <origin xyz="0.06 0.06 -0.035"/>
    <axis xyz="0 1 0"/>
  </joint>

<!-- ******************************* 2 ******************************** -->
  <!-- set front_right_wheel  -->
  <link name="front_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="black"/>
      <origin rpy="1.57 0.0 0.0"/>
    </visual>
  </link>

  <!-- set joint front_right_wheel to base_link  -->
  <joint name="front_right_wheel_to_base_link" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.06 -0.06 -0.035"/>
    <axis xyz="0 1 0"/>
  </joint>
  
<!-- ******************************* 3 ******************************** -->
  <!-- set back_left_wheel  -->
  <link name="back_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="black"/>
      <origin rpy="1.57 0.0 0.0"/>
    </visual>
  </link>

  <!-- set joint back_left_wheel to base_link  -->
  <joint name="back_left_wheel_to_base_link" type="continuous">
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <origin xyz="-0.06 0.06 -0.035"/>
    <axis xyz="0 1 0"/>
  </joint>

<!-- ******************************* 4 ******************************** -->
  <!-- set back_right_wheel  -->
  <link name="back_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="black"/>
      <origin rpy="1.57 0.0 0.0"/>
    </visual>
  </link>

  <!-- set joint back_right_wheel to base_link  -->
  <joint name="back_right_wheel_to_base_link" type="continuous">
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <origin xyz="-0.06 -0.06 -0.035"/>
    <axis xyz="0 1 0"/>
  </joint>
</robot>