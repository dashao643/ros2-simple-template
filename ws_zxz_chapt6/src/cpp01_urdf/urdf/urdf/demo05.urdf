<robot name="robot_joint">
  <material name="test_color1">
  <color rgba="0.8 0.2 0.4 0.5"/>
  </material>
  <material name="test_color2">
  <color rgba="0.4 0.8 0.2 0.5"/>
  </material>

  <link name="base_footprint">
    <visual>
      <geometry>
        <sphere radius="0.001"/>
      </geometry>
    </visual>
  </link>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.4 0.2"/>
      </geometry>
       <material name="test_color1"/>
    </visual>
  </link>

  <joint name="base_link2base_footprint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.1"/>
  </joint>

  <link name="camera">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
       <material name="test_color2"/>
    </visual>
  </link>

  <joint name="camera2base_link" type="continuous">
    <parent link="base_link"/>
    <child link="camera"/>
    <!-- offset -->
    <origin xyz="0.2 0.0 0.12"/>
    <!-- rotation axis -->
    <axis xyz="0 0 1"/>
  </joint>

</robot>