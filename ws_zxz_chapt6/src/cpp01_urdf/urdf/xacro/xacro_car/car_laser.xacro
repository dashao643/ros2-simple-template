<!-- 雷达 -->
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:property name="laser_radius" value="0.03"/>
  <xacro:property name="laser_length" value="0.03"/>

  <xacro:property name="laser_x_offset" value="0.0"/>
  <xacro:property name="laser_y_offset" value="0.0"/>
  <xacro:property name="laser_z_offset" value="${car_height / 2 + laser_length / 2}"/>

  <link name="laser">
    <visual>
      <geometry>
        <cylinder radius="${laser_radius}" length="${laser_length}"/>
      </geometry>

      <material name="pink"/>

      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    </visual>
  </link>

  <joint name="laser_to_baselink" type="continuous">
    <parent link="base_link"/>
    <child link="laser"/>
    <axis xyz="0 0 1"/>
    <origin xyz="${laser_x_offset} ${laser_y_offset} ${laser_z_offset}" rpy="0.0 0.0 0.0"/>
  </joint>
</robot>