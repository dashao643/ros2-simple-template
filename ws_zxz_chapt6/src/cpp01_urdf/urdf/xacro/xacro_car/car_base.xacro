<!-- 底盘实现 -->
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <!-- 声明变量 -->
  <xacro:property name="PI" value="3.1415927"/>

  <xacro:property name="car_length" value="0.2"/>
  <xacro:property name="car_width" value="0.12"/>
  <xacro:property name="car_height" value="0.07"/>

  <xacro:property name="wheel_radius" value="0.025"/>
  <xacro:property name="wheel_length" value="0.02"/>

  <!-- 离地间距 0.025+0.035=0.06 -->
  <xacro:property name="distance" value="${wheel_radius + car_height / 2}"/>

  <!-- 车轮偏移 -->
  <xacro:property name="wheel_offset" value="0.06"/>

  <!-- set color -->
  <material name="yellow">
    <color rgba="0.9 0.6 0.0 0.5"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 0.5"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.1 0.1 0.8"/>
  </material>
  <material name="pink">
    <color rgba="0.4 0.2 0.6 0.8"/>
  </material>

  <!-- set base_footprint -->
  <link name="base_footprint">
    <visual>
      <geometry>
        <sphere radius="0.001"/>
      </geometry>
    </visual>
  </link>

  <!-- set base_link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${car_length} ${car_width} ${car_height}"/>
      </geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <!-- 关联 base_link 和 base_footprint -->
  <joint name="base_link2base_footprint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 ${distance}"/>
  </joint>

  <!-- 定义车轮宏(创建车轮, 和车轮关节 -->
  <xacro:macro name="wheel_create" params="wheel_name is_front is_left">
    <!-- 创建车轮 -->
    <link name="${wheel_name}">
      <visual>
        <!-- 设置形状 -->
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
        </geometry>
        <!-- 角度设置偏移 -->
        <origin rpy="${PI / 2} 0 0"/>
        <!-- 设置颜色 -->
        <material name="black"/>
      </visual>
    </link>
    <!-- 配置关节 -->
    <joint name="${wheel_name}_to_baselink" type="continuous">
      <origin xyz="${wheel_offset * is_front} ${wheel_offset * is_left} -0.035"/>
      <parent link="base_link"/>
      <child link="${wheel_name}"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- 车轮宏调用 -->
  <xacro:wheel_create wheel_name="left_front_wheel" is_front="1" is_left="1"/>
  <xacro:wheel_create wheel_name="right_front_wheel" is_front="1" is_left="-1"/>
  <xacro:wheel_create wheel_name="left_back_wheel" is_front="-1" is_left="1"/>
  <xacro:wheel_create wheel_name="right_back_wheel" is_front="-1" is_left="-1"/>
</robot>