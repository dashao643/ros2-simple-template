# ============================================
# ROS2 工程专用 .gitignore
# 适用于 ROS2 Humble/Humble 及以上版本
# ============================================

# ---------------------------
# 编译产物
# ---------------------------
build/
log/
install/
*_ws/build/
*_ws/log/
*_ws/install/

# CMake 生成文件
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
CMakeUserPresets.json
compile_commands.json

# ---------------------------
# Python 编译产物
# ---------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.dll
*.dylib

# ---------------------------
# 开发工具
# ---------------------------
# VS Code
.vscode/
*.code-workspace

# ---------------------------
# 日志和临时文件
# ---------------------------
*.log
*.bag
*.db3
*.mp4
*.avi
*.png
*.jpg
core.*
*.core
*.pid

# ---------------------------
# 系统文件
# ---------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------
# 环境配置（敏感信息）
# ---------------------------
.env
*.env
.env.local
.ros/
.ros2/

# ---------------------------
# 文档生成
# ---------------------------
doc/html/
doc/latex/
*.aux
*.out

# ---------------------------
# 依赖管理
# ---------------------------
# vcpkg
vcpkg_installed/
vcpkg-manifest-install.log

# conan
conaninfo.txt
conanbuildinfo.*